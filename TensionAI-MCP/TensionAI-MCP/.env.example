# Adversarial MCP Server Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# LLM Provider API Keys (at least one required)
# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Anthropic (recommended for Phase 1)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# MiniMax API (Phase 2+)
# Get your API key from: https://platform.minimax.chat/
MINIMAX_API_KEY=your-minimax-key
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=abab6.5s-chat

# Google Gemini API (Phase 2+)
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-key
GEMINI_MODEL=gemini-2.0-flash-exp

# Local Models (Phase 2+)
# vLLM - High-performance LLM serving
# Start with: python -m vllm.entrypoints.openai.api_server --model <model>
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL=llama-3-8b

# llama.cpp - CPU-efficient inference
# Start with: llama-server --model <model.gguf> --port 8080
LLAMA_CPP_URL=http://localhost:8080
LLAMA_CPP_MODEL=llama-3-8b

# Custom Pricing (optional, per 1M tokens in USD)
# Format: PROVIDER_INPUT_PRICE, PROVIDER_OUTPUT_PRICE
# Example:
# OPENAI_INPUT_PRICE=2.50
# OPENAI_OUTPUT_PRICE=10.00

# Workspace Configuration
WORKSPACE_DIR=./workspace

# Memory System Configuration (Phase 5)
# Memory provider: local, openmemory, cognee, mem0
MEMORY_PROVIDER=local

# Embedding model for vector search
EMBEDDING_MODEL=text-embedding-3-small

# OpenMemory API (optional)
# Get your API key from: https://openmemory.io/
OPENMEMORY_API_KEY=your-openmemory-key
OPENMEMORY_BASE_URL=https://api.openmemory.io/v1

# Cognee API (optional)
# Get your API key from: https://cognee.ai/
COGNEE_API_KEY=your-cognee-key
COGNEE_BASE_URL=https://api.cognee.ai/v1

# Mem0 API (optional)
# Get your API key from: https://mem0.ai/
MEM0_API_KEY=your-mem0-key
MEM0_BASE_URL=https://api.mem0.ai/v1