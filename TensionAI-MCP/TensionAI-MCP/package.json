{
  "name": "tensionai-mcp",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "TensionAI-MCP: Multi-Agent MCP Server with Planner/Generator/Evaluator architecture",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "mcp": "bun run src/mcp/stdio.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "test": "bun test",
    "test:e2e": "bun test tests/e2e",
    "benchmark": "bun run scripts/benchmark.ts",
    "cli": "bun run src/cli/client.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/websocket": "^11.0.0",
    "@modelcontextprotocol/sdk": "^1.1.0",
    "fastify": "^5.3.0",
    "openai": "^4.85.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
